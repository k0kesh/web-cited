# Cloudflare Pages headers config.
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

/*
  # HSTS, intentional ramp:
  #   Initial Cloudflare Pages cutover: max-age=300 (5 minutes).
  #     Lets us roll back fast if any TLS / hosting issue surfaces in the
  #     first day. Browsers honoring this won't be locked into HTTPS
  #     beyond the 5-minute window.
  #   2026-04-30 (24+ hrs stable behavior): bumped to 86400 (1 day).
  #   After 7 days of stable behavior: bump to 31536000 (1 year).
  #   After 30 days of stable behavior: bump to 63072000 (2 years).
  #   At 2-year max-age + 30+ days of stability: submit to https://hstspreload.org.
  # The includeSubDomains flag is safe today: every web-cited subdomain
  # (api, audit, artifacts) already uses HTTPS.
  Strict-Transport-Security: max-age=86400; includeSubDomains

  # Standard security headers.
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()

  # Strict Content Security Policy (item W, 2026-04-28).
  #
  # All inline JS extracted to /js/start.js + /js/contact.js; all inline
  # styles extracted to utility classes; honeypot positioning moved from
  # inline style to .honeypot-field class (other defense layers preserved).
  # JSON-LD scripts remain inline but browsers exempt application/ld+json
  # from script-src per the HTML spec (this is the universal browser
  # behavior; we intentionally do NOT noncify JSON-LD to keep this static).
  #
  # Allowed sources:
  # - script-src: self (own origin) + Cloudflare Turnstile bot-defense.
  # - style-src: self only. No inline styles anywhere.
  # - img-src: self + data: (for inline favicons + small UI bitmaps).
  # - font-src: self.
  # - connect-src: self + api.web-cited.com (intake submissions) +
  #   Cloudflare Turnstile.
  # - frame-src: Cloudflare Turnstile (challenge widget iframe).
  # - object-src: none (legacy plugins blocked).
  # - base-uri: self (prevents <base href> hijacks).
  # - form-action: self + api.web-cited.com (legacy fallback if any form
  #   ever submits with method=POST + action=).
  # - frame-ancestors: none (anti-clickjacking; complements X-Frame-Options).
  # - upgrade-insecure-requests: forces HTTP -> HTTPS on any subresource.
  #
  # If a CSP violation surfaces in production, check browser DevTools
  # console for the exact Refused-to-execute / Refused-to-apply line and
  # extend the relevant directive. Do NOT add 'unsafe-inline' or
  # 'unsafe-eval' under any circumstance.
  Content-Security-Policy: default-src 'self'; script-src 'self' https://challenges.cloudflare.com; style-src 'self'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://api.web-cited.com https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self' https://api.web-cited.com; frame-ancestors 'none'; upgrade-insecure-requests

# NOTE on Cache-Control: Cloudflare Pages _headers is ADDITIVE: a global
# Cache-Control on /* would append to per-path rules below and (because
# browsers honor the first max-age) silently shorten the cache of every
# long-cache asset. We therefore set Cache-Control per path (HTML + assets
# below) rather than once at /*.

# HTML pages: 5-minute edge cache, must-revalidate.
# Plus a Link: rel=preload header for the stylesheet so supporting browsers
# fetch CSS in parallel with HTML parse instead of waiting until the
# `<link rel=stylesheet>` tag is seen. Same effect as adding the preload
# tag inline, but applied centrally to every HTML route.
/*.html
  Cache-Control: public, max-age=300, must-revalidate
  Link: </css/styles.css?v=2026-04-28w>; rel=preload; as=style

# Clean URLs (Cloudflare Pages auto-redirects .html to clean URL).
/
  Cache-Control: public, max-age=300, must-revalidate
  Link: </css/styles.css?v=2026-04-28w>; rel=preload; as=style

# Long-cache static assets (CSS, JS, fonts, images, favicons).
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/og/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=31536000, immutable

/apple-touch-icon.png
  Cache-Control: public, max-age=31536000, immutable

/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600

# Customer-facing sample artifacts (Q9:A 2026-05-03).
#
# The H7-locked Claimzilla Playbook sample at `/docs/sample/playbook-claimzilla.html`
# is a self-contained HTML deliverable matching the production Playbook
# format that ships from `artifacts.web-cited.com/{deal_id}/{brand}/playbook/index.html`
# to paying customers. By design it carries:
#   - one inline `<style>` block (the Playbook's CSS)
#   - one inline `<script>` block (the tab-nav handler)
#   - inline `style="..."` attributes on a handful of elements
#
# The site-wide CSP from item W (2026-04-28, `/*` block above) blocks all
# of those because `script-src 'self'` + `style-src 'self'` exclude inline.
# Cold-email recipients clicking the sample link from the outbound batch 1
# templates saw an unstyled blank-looking page (caught 2026-05-03).
#
# This block UNSETS the inherited strict CSP for `/docs/sample/*` and
# substitutes a relaxed CSP that allows `'unsafe-inline'` for style + script.
# Scope-limited to the sample directory: every other route on the site
# (start.html, pricing.html, services.html, etc.) keeps the strict CSP from
# the `/*` block. The sample directory contains no user input, no auth
# forms, no fetch endpoints; it is purely static deliverable HTML we ship.
# The risk profile of "we can inject inline JS into our own sample HTML"
# is the same as the risk profile of `/js/start.js` and `/js/contact.js`.
#
# Cloudflare Pages `_headers` is additive by default; the leading
# `! Content-Security-Policy` line removes the inherited strict CSP so
# the relaxed version below is the only CSP browsers see for these paths.
/docs/sample/*
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'
  Cache-Control: public, max-age=300, must-revalidate
